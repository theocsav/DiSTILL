# Copy to .env and fill in real values before running docker compose.
BASIC_AUTH_USER=lab-user
BASIC_AUTH_PASS=change-me
AUTH_PASSWORD_HASH=
SESSION_SECRET=change-me-please
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=sptx_csrf
CSRF_HEADER_NAME=X-CSRF-Token
ARTIFACT_ROOTS=/app/runs
RUN_RETENTION_DAYS=30
CLEANUP_INTERVAL_SECONDS=3600
PREFLIGHT_SLURM_FALLBACK=false
PREFLIGHT_CACHE_TTL_SECONDS=300
PREFLIGHT_CHECK_PATHS=true
SLURM_BACKEND=local
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=
SSH_KNOWN_HOSTS=
SSH_STRICT_HOST_KEY_CHECKING=yes
SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_REMOTE_RUNS_DIR=
QUEUE_POLLER_TOKEN=
QUEUE_CLAIM_LEASE_SECONDS=600
DISK_WARN_FREE_GB=50
DISK_WARN_PERCENT=10
QUEUE_ENABLED=true
WORKER_POLL_SECONDS=10
NEXT_PUBLIC_API_BASE=http://localhost:8000
